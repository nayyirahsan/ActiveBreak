{
  "manifest_version": 3,
  "name": "ActiveBreak - AI-Powered Productivity Timer",
  "version": "1.0.0",
  "description": "Enforces exercise breaks using AI-powered webcam tracking to verify completion before resuming work.",
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "500": "icons/logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/overlay.js"],
      "css": ["content/overlay.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/overlay.html", "content/overlay.css"],
      "matches": ["<all_urls>"]
    }
  ]
} 