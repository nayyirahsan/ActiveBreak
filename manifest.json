{
  "manifest_version": 3,
  "name": "ActiveBreak - Exercise Break Timer",
  "version": "2.0.0",
  "description": "Enforces healthy exercise breaks. When time is up, your screen locks until on-device AI pose detection verifies your reps.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/logo.png"
    }
  },
  "icons": {
    "128": "icons/logo.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/overlay.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
